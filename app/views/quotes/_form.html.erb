<%= simple_form_for quote, html: { class: "space-y-6" } do |f| %>
  <%# Exibe erros de validação se houver %>
  <%= f.error_notification %>

  <%# Campo do nome %>
  <div>
    <%= f.input :name,

        input_html: {
          autofocus: true,
          class: "w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        },
        label_html: { class: "block text-sm font-medium text-gray-700 mb-2" } %>
  </div>

  <%# Botões de ação %>
  <div class="flex items-center space-x-4">
    <%= f.button :submit,
        class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-6 rounded-lg transition duration-200 cursor-pointer" %>
    <%= link_to "Cancel",
        quotes_path,
        class: "bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold py-2 px-6 rounded-lg transition duration-200" %>
  </div>
<% end %>
