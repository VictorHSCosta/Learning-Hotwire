<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <div class="bg-white shadow-xl rounded-lg p-8">
      <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-bold text-gray-900">Quotes</h1>
        <%= link_to "New Quote",
            new_quote_path,
            data: { turbo_frame: dom_id(Quote.new) },
            class: "bg-green-500 hover:bg-green-600 text-white font-semibold py-2 px-6 rounded-lg transition duration-200" %>
      </div>

      <%# Mensagens de notice/alert %>
      <% if notice %>
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
          <%= alert %>
        </div>
      <% end %>

      <%= turbo_frame_tag Quote.new %>

      <%# Lista de quotes %>
      <%= turbo_frame_tag "quotes" do %>
        <div class="space-y-4">
          <% if @quotes.any? %>
            <% @quotes.each do |quote| %>
              <%= render "quote", quote: quote %>
            <% end %>
          <% else %>
            <div class="text-center py-12">
              <p class="text-gray-500 text-lg">No quotes yet.</p>
              <p class="text-gray-400 text-sm mt-2">Create your first quote to get started!</p>
            </div>
          <% end %>
        </div>
      <% end %>
      
      </div>
    </div>
  </div>
</div>
