<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto">
    <div class="bg-white shadow-xl rounded-lg p-8">
      <div class="mb-6">
        <%= link_to "← Back to Quotes",
            quotes_path,
            class: "text-blue-500 hover:text-blue-600 font-medium" %>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 mb-6">
        <%= @quote.name %>
      </h1>

      <div class="space-y-4 mb-8">
        <div class="flex items-center text-gray-600">
          <span class="font-medium">Created by:</span>
          <span class="ml-2"><%= @quote.user.email %></span>
        </div>

        <div class="flex items-center text-gray-600">
          <span class="font-medium">Created at:</span>
          <span class="ml-2"><%= @quote.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
        </div>

        <div class="flex items-center text-gray-600">
          <span class="font-medium">Last updated:</span>
          <span class="ml-2"><%= time_ago_in_words(@quote.updated_at) %> ago</span>
        </div>
      </div>

      <% if @quote.user == current_user %>
        <div class="flex items-center space-x-4 pt-6 border-t border-gray-200">
          <%= link_to "Edit",
              edit_quote_path(@quote),
              class: "bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2 px-6 rounded-lg transition duration-200" %>
          <%= button_to "Delete",
              quote_path(@quote),
              method: :delete,
              data: { confirm: "Are you sure you want to delete this quote?" },
              class: "bg-red-500 hover:bg-red-600 text-white font-semibold py-2 px-6 rounded-lg transition duration-200" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
